{
  "info": {
    "name": "StudentJobs API",
    "_postman_id": "studentjobs-collection-v1",
    "description": "Все эндпоинты StudentJobs с примерами запросов",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "token",    "value": "YOUR_TOKEN_HERE" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student1\",\n  \"password\": \"pass1234\",\n  \"email\": \"student@kbtu.kz\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"token\": \"abc123...\",\n  \"user\": { \"id\": 1, \"username\": \"student1\", \"email\": \"student@kbtu.kz\" }\n}"
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student1\",\n  \"password\": \"pass1234\"\n}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"token\": \"abc123...\",\n  \"user\": { \"id\": 1, \"username\": \"student1\" }\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{ \"error\": \"Invalid credentials\" }"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": "{{base_url}}/auth/logout/",
            "body": { "mode": "raw", "raw": "{}" }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{ \"message\": \"Logged out successfully\" }"
            }
          ]
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "List Jobs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": {
              "raw": "{{base_url}}/jobs/",
              "query": [{ "key": "job_type", "value": "internship", "disabled": true }]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"title\": \"Junior Frontend Developer\",\n    \"company_name\": \"TechCorp\",\n    \"job_type\": \"internship\",\n    \"salary\": 150000,\n    \"location\": \"Алматы\",\n    \"is_active\": true\n  }\n]"
            }
          ]
        },
        {
          "name": "Get Job Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": "{{base_url}}/jobs/1/"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"title\": \"Junior Frontend Developer\",\n  \"description\": \"Ищем студента...\",\n  \"company_name\": \"TechCorp\",\n  \"job_type\": \"internship\",\n  \"salary\": 150000,\n  \"location\": \"Алматы\"\n}"
            }
          ]
        },
        {
          "name": "Create Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": "{{base_url}}/jobs/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Python Developer Intern\",\n  \"description\": \"Ищем студента знающего Django\",\n  \"job_type\": \"internship\",\n  \"salary\": 120000,\n  \"location\": \"Алматы / Remote\",\n  \"company\": 1\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{ \"id\": 2, \"title\": \"Python Developer Intern\", \"created_by_name\": \"student1\" }"
            }
          ]
        },
        {
          "name": "Update Job",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": "{{base_url}}/jobs/1/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"salary\": 200000\n}"
            }
          },
          "response": [
            { "name": "200 OK", "status": "OK", "code": 200, "body": "{ \"id\": 1, \"salary\": 200000 }" }
          ]
        },
        {
          "name": "Delete Job",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": "{{base_url}}/jobs/1/"
          },
          "response": [
            { "name": "204 No Content", "status": "No Content", "code": 204, "body": "" }
          ]
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "My Applications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": "{{base_url}}/applications/"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"job_title\": \"Junior Frontend Developer\",\n    \"status\": \"pending\",\n    \"applied_at\": \"2026-04-01T12:00:00Z\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Apply to Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": "{{base_url}}/applications/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"job\": 1,\n  \"cover_letter\": \"Я студент 3 курса КБТУ, изучаю Angular и Django...\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{ \"id\": 1, \"job\": 1, \"status\": \"pending\" }"
            }
          ]
        },
        {
          "name": "Update Application Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": "{{base_url}}/applications/1/status/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"accepted\"\n}"
            }
          },
          "response": [
            { "name": "200 OK", "status": "OK", "code": 200, "body": "{ \"id\": 1, \"status\": \"accepted\" }" }
          ]
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": "{{base_url}}/profile/"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"university\": \"КБТУ\",\n  \"major\": \"Информационные системы\",\n  \"grad_year\": 2026,\n  \"bio\": \"\",\n  \"resume_url\": \"\"\n}"
            }
          ]
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": "{{base_url}}/profile/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"university\": \"КБТУ\",\n  \"major\": \"Информационные системы\",\n  \"grad_year\": 2026,\n  \"bio\": \"Студент 3 курса, люблю Python и Angular\",\n  \"resume_url\": \"https://drive.google.com/my-resume\"\n}"
            }
          },
          "response": [
            { "name": "200 OK", "status": "OK", "code": 200, "body": "{ \"university\": \"КБТУ\", \"major\": \"Информационные системы\" }" }
          ]
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        {
          "name": "List Companies",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": "{{base_url}}/companies/"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[{ \"id\": 1, \"name\": \"TechCorp KZ\", \"website\": \"https://techcorp.kz\" }]"
            }
          ]
        },
        {
          "name": "Create Company",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": "{{base_url}}/companies/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"TechCorp KZ\",\n  \"description\": \"IT-компания в Алматы\",\n  \"website\": \"https://techcorp.kz\"\n}"
            }
          },
          "response": [
            { "name": "201 Created", "status": "Created", "code": 201, "body": "{ \"id\": 1, \"name\": \"TechCorp KZ\" }" }
          ]
        }
      ]
    }
  ]
}
